# ==============================================================
# Copy this file to `.env` and fill in the values for your
# environment. NEVER commit `.env` — it is git-ignored.
#
# IMPORTANT: If a real secret has previously been committed,
# rotate it at the identity provider / message broker before
# redeploying.
# ==============================================================

# --- Database ---
DB_URL=jdbc:postgresql://localhost:5432/nurtricenter_patient_db
DB_USER=postgres
DB_PASSWORD=change-me

# --- JPA / Flyway ---
# Use `validate` (or `none`) in production; Flyway manages the schema.
SPRING_JPA_HIBERNATE_DDL_AUTO=update
JPA_GENERATE_DDL=false
FLYWAY_ENABLED=false

# --- Keycloak ---
KEYCLOAK_BASE_URL=http://keycloak:8080
KEYCLOAK_REALM=your-realm
KEYCLOAK_CLIENT_ID=your-client-id
KEYCLOAK_CLIENT_SECRET=change-me
KEYCLOAK_ISSUER=http://keycloak:8080/realms/your-realm
KEYCLOAK_JWKS_TTL=600
KEYCLOAK_BLOCKED_USERS=

# --- RabbitMQ (outbox publisher) ---
EVENTBUS_DRIVER=rabbitmq
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=change-me
RABBITMQ_VHOST=/
RABBITMQ_EXCHANGE=outbox.events
RABBITMQ_EXCHANGE_TYPE=fanout
RABBITMQ_EXCHANGE_DURABLE=true
RABBITMQ_ROUTING_KEY=
RABBITMQ_QUEUE=
RABBITMQ_QUEUE_DURABLE=true
RABBITMQ_QUEUE_EXCLUSIVE=false
RABBITMQ_QUEUE_AUTO_DELETE=false
RABBITMQ_BINDING_KEY=
RABBITMQ_DECLARE_TOPOLOGY=false
RABBITMQ_PUBLISH_RETRIES=3
RABBITMQ_PUBLISH_BACKOFF_MS=250
RABBITMQ_CONNECT_TIMEOUT=5
RABBITMQ_READ_WRITE_TIMEOUT=5
RABBITMQ_OUTBOX_BATCH_SIZE=50
RABBITMQ_OUTBOX_POLL_INTERVAL_MS=1000

# --- Inbound RabbitMQ consumer ---
INBOUND_SCHEMA_VERSIONS=1
INBOUND_RABBITMQ_ENABLED=true
INBOUND_RABBITMQ_EXCHANGE=outbox.events
INBOUND_RABBITMQ_EXCHANGE_TYPE=fanout
INBOUND_RABBITMQ_EXCHANGE_DURABLE=true
INBOUND_RABBITMQ_QUEUE=pacientes.inbound
INBOUND_RABBITMQ_QUEUE_DURABLE=true
INBOUND_RABBITMQ_QUEUE_EXCLUSIVE=false
INBOUND_RABBITMQ_QUEUE_AUTO_DELETE=false
INBOUND_RABBITMQ_DECLARE_TOPOLOGY=false
INBOUND_RABBITMQ_FAIL_FAST_ON_MISSING_QUEUE=false
INBOUND_RABBITMQ_ROUTING_KEYS=suscripciones.suscripcion-actualizada,suscripciones.suscripcion-eliminada,contrato.creado,contrato.cancelado,contrato.cancelar
INBOUND_RABBITMQ_RETRY_EXCHANGE=
INBOUND_RABBITMQ_RETRY_QUEUE=
INBOUND_RABBITMQ_RETRY_ROUTING_KEY=
INBOUND_RABBITMQ_RETRY_DELAYS=10,60,300
