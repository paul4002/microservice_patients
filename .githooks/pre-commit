#!/usr/bin/env bash
# Pre-commit hook: formatea código y ejecuta tests antes del commit.
# Instalar: ./scripts/install-hooks.sh

set -e

cd "$(git rev-parse --show-toplevel)"

echo "[pre-commit] Spotless apply..."
./mvnw -q spotless:apply || {
  echo "[pre-commit] Spotless failed. Aborting commit." >&2
  exit 1
}

echo "[pre-commit] Re-staging formatted files..."
git add -u

echo "[pre-commit] mvn test (skip integration)..."
./mvnw -q -DskipITs=true test || {
  echo "[pre-commit] Tests failed. Aborting commit." >&2
  exit 1
}

echo "[pre-commit] OK"
